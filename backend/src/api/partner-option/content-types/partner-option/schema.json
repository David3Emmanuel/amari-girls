{
  "kind": "collectionType",
  "collectionName": "partner_options",
  "info": {
    "singularName": "partner-option",
    "pluralName": "partner-options",
    "displayName": "Partner Option"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "num": {
      "type": "string",
      "required": true,
      "unique": true,
      "regex": "[0-9]+"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "ctaLabel": {
      "type": "string",
      "required": true
    },
    "ctaHref": {
      "type": "string",
      "required": true
    },
    "accent": {
      "type": "boolean",
      "default": false
    },
    "sortOrder": {
      "type": "integer",
      "required": true,
      "default": 0
    }
  }
}
