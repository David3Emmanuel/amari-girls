{
  "kind": "collectionType",
  "collectionName": "reports",
  "info": {
    "singularName": "report",
    "pluralName": "reports",
    "displayName": "Report"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "year": {
      "type": "integer",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Annual Report",
        "Budget",
        "Auditor Report",
        "Financial Statement",
        "Grants/Donors"
      ]
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "files": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "files"
      ]
    }
  }
}
